<?xml version="1.0" encoding="UTF-8"?>
<actions>
    <!--
      Force GlassFish 8 client bootstrap via run-client.sh.
      Default NetBeans Run File clears exec.vmArgs and causes NoInitialContextException.
    -->
    <action>
        <actionName>run.single</actionName>
        <packagings>
            <packaging>*</packaging>
        </packagings>
        <goals>
            <goal>process-classes</goal>
            <goal>org.codehaus.mojo:exec-maven-plugin:3.5.1:exec</goal>
        </goals>
        <properties>
            <exec.executable>${basedir}/run-client.sh</exec.executable>
            <exec.args>${packageClassName}</exec.args>
            <exec.classpathScope>runtime</exec.classpathScope>
        </properties>
    </action>
    <action>
        <actionName>run</actionName>
        <packagings>
            <packaging>*</packaging>
        </packagings>
        <goals>
            <goal>process-classes</goal>
            <goal>org.codehaus.mojo:exec-maven-plugin:3.5.1:exec</goal>
        </goals>
        <properties>
            <exec.executable>${basedir}/run-client.sh</exec.executable>
            <exec.args>avilawebservice.test.TestHolaMundoEJB</exec.args>
            <exec.classpathScope>runtime</exec.classpathScope>
        </properties>
    </action>
    <action>
        <actionName>debug.single</actionName>
        <packagings>
            <packaging>*</packaging>
        </packagings>
        <goals>
            <goal>process-classes</goal>
            <goal>org.codehaus.mojo:exec-maven-plugin:3.5.1:exec</goal>
        </goals>
        <properties>
            <exec.executable>${basedir}/run-client.sh</exec.executable>
            <exec.args>${packageClassName}</exec.args>
            <exec.classpathScope>runtime</exec.classpathScope>
        </properties>
    </action>
</actions>
