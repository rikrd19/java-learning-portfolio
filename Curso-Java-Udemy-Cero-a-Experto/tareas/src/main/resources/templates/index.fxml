<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="group_avila.tareas.controlador.IndexControlador">
   <children>
      <Label layoutX="190.0" layoutY="43.0" text="Sistema de Tareas" textFill="#e13737">
         <font>
            <Font name="Arial Bold" size="25.0" />
         </font></Label>
      <TableView fx:id="tareaTabla" layoutX="229.0" layoutY="89.0" onMouseClicked="#cargarTareaFormulario" prefHeight="199.0" prefWidth="350.0">
        <columns>
          <TableColumn fx:id="idTareaColumna" prefWidth="37.0" text="ID" />
          <TableColumn fx:id="nombreTareaColumna" prefWidth="119.0" text="Tarea" />
            <TableColumn fx:id="responsableColumna" prefWidth="97.0" text="Responsable" />
            <TableColumn fx:id="estatusColumna" prefWidth="92.0" text="Estatus" />
        </columns>
      </TableView>
      <AnchorPane layoutX="26.0" layoutY="92.0" prefHeight="92.0" prefWidth="204.0">
         <children>
            <AnchorPane layoutX="8.0" prefHeight="193.0" prefWidth="189.0">
               <children>
                  <Label layoutX="14.0" layoutY="14.0" text="Tarea" textFill="#457b9d">
                     <font>
                        <Font name="System Bold" size="16.0" />
                     </font>
                  </Label>
                  <Label layoutX="16.0" layoutY="74.0" text="Responsable" textFill="#457b9d">
                     <font>
                        <Font name="System Bold" size="16.0" />
                     </font>
                  </Label>
                  <Label layoutX="16.0" layoutY="131.0" text="Estatus" textFill="#457b9d">
                     <font>
                        <Font name="System Bold" size="16.0" />
                     </font></Label>
                  <TextField fx:id="nombreTareaTexto" layoutX="14.0" layoutY="31.0" />
                  <TextField fx:id="responsableTexto" layoutX="14.0" layoutY="94.0" />
                  <TextField fx:id="estatusTexto" layoutX="14.0" layoutY="151.0" />
               </children>
            </AnchorPane>
         </children>
      </AnchorPane>
      <AnchorPane layoutX="17.0" layoutY="316.0" prefHeight="69.0" prefWidth="552.0">
         <children>
            <Button fx:id="agregarBoton" layoutX="31.0" layoutY="18.0" mnemonicParsing="false" onAction="#agregarTarea" prefHeight="30.0" prefWidth="71.0" style="-fx-background-color: #1d3557;" text="Agregar" textFill="#f1faee" />
            <Button fx:id="modificarBoton" layoutX="134.0" layoutY="18.0" mnemonicParsing="false" onAction="#modificarTarea" prefHeight="30.0" prefWidth="79.0" style="-fx-background-color: #1d3557;" text="Modificar" textFill="#f1faee" />
            <Button fx:id="eliminarBoton" layoutX="252.0" layoutY="18.0" mnemonicParsing="false" onAction="#eliminarTarea" prefHeight="30.0" prefWidth="71.0" style="-fx-background-color: #e63946;" text="Eliminar" textFill="#f1faee" />
            <Button fx:id="limpiarBoton" layoutX="360.0" layoutY="19.0" mnemonicParsing="false" onAction="#limpiarFormulario" prefHeight="30.0" prefWidth="160.0" style="-fx-background-color: #ffd60a;" text="Limpiar Forma" />
         </children>
      </AnchorPane>
   </children>
</AnchorPane>
