<?xml version="1.0" encoding="UTF-8"?>
<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence
                                 https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd"
             version="3.0">

    <!--
      persistence-unit name = alias you use in Java:
      Persistence.createEntityManagerFactory("PersonaPU")
    -->
    <persistence-unit name="PersonaPU" transaction-type="RESOURCE_LOCAL">
        <!-- EclipseLink (from your pom dependency) -->
        <provider>org.eclipse.persistence.jpa.PersistenceProvider</provider>

        <!-- Required in Java SE: list entities (classpath scan is not reliable) -->
        <class>avilawebservice.domain.Persona</class>
        <exclude-unlisted-classes>false</exclude-unlisted-classes>

        <properties>
            <!-- JDBC: standard keys defined by the JPA/Jakarta Persistence spec -->
            <property name="jakarta.persistence.jdbc.driver" value="com.mysql.cj.jdbc.Driver"/>
            <property name="jakarta.persistence.jdbc.url" value="jdbc:mysql://localhost:3306/test?useSSL=false&amp;serverTimezone=UTC"/>
            <property name="jakarta.persistence.jdbc.user" value="root"/>
            <property name="jakarta.persistence.jdbc.password" value="curso*123"/>

            <!-- EclipseLink-specific properties (provider docs, not "magic") -->
            <property name="eclipselink.logging.level" value="FINE"/>
            <property name="eclipselink.ddl-generation" value="create-or-extend-tables"/>
        </properties>
    </persistence-unit>
</persistence>
