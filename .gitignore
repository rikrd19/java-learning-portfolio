# =============================================================================
# Java Learning Portfolio — unified root .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Operating system
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db

# -----------------------------------------------------------------------------
# IntelliJ IDEA
# -----------------------------------------------------------------------------
.idea/
*.iml
*.iws
*.ipr
out/

# -----------------------------------------------------------------------------
# Eclipse / STS
# -----------------------------------------------------------------------------
.apt_generated
.classpath
.factorypath
.project
.settings/
.springBeans
.sts4-cache
bin/

# -----------------------------------------------------------------------------
# NetBeans
# -----------------------------------------------------------------------------
nbproject/private/
nbbuild/
dist/
nbdist/
.nb-gradle/

# -----------------------------------------------------------------------------
# VS Code
# -----------------------------------------------------------------------------
.vscode/

# -----------------------------------------------------------------------------
# Java compiled output
# -----------------------------------------------------------------------------
*.class

# -----------------------------------------------------------------------------
# Build directories (Maven, Gradle, frontend)
# -----------------------------------------------------------------------------
target/
build/
**/target/
**/build/
.gradle/

# -----------------------------------------------------------------------------
# Maven
# -----------------------------------------------------------------------------
.mvn/wrapper/maven-wrapper.jar

# -----------------------------------------------------------------------------
# Node.js / React / Angular
# -----------------------------------------------------------------------------
node_modules/
.pnp
.pnp.js
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# -----------------------------------------------------------------------------
# Frontend production & test artifacts
# -----------------------------------------------------------------------------
coverage/
.eslintcache

# -----------------------------------------------------------------------------
# Environment & secrets
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example

# -----------------------------------------------------------------------------
# Logs & temporary files
# -----------------------------------------------------------------------------
*.log
*.tmp
*.bak
*.swp
*~

# -----------------------------------------------------------------------------
# Binary artifacts
# -----------------------------------------------------------------------------
*.jar
*.war
*.ear
*.zip

# Keep Maven wrapper JAR (negate rule above)
!**/.mvn/wrapper/maven-wrapper.jar

# -----------------------------------------------------------------------------
# Application servers (local installations — do not commit)
# -----------------------------------------------------------------------------
**/GlassFish_Server/
**/glassfish/domains/

# -----------------------------------------------------------------------------
# Spring Boot generated help
# -----------------------------------------------------------------------------
HELP.md
